<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- List View -->
    <record id="view_package_rule_list" model="ir.ui.view">
        <field name="name">package.rule.list</field>
        <field name="model">package.rule</field>
        <field name="arch" type="xml">
            <list string="Package Templates">
                <field name="active" invisible="1"/>
                <field name="name"/>
                <field name="duration"/>
                <field name="discount_per"/>
                <field name="total_value"/>
                <field name="package_amount"/>
                <field name="valid"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_package_rule_form" model="ir.ui.view">
        <field name="name">package.rule.form</field>
        <field name="model">package.rule</field>
        <field name="arch" type="xml">
            <form string="Package Template">

                <header>

    <button name="action_create_package_product"
            string="Create POS Product"
            type="object"
            class="oe_highlight"
            icon="fa-plus"
            invisible="product_id or is_locked"/>

    <button name="action_update_package_product"
            string="Update Product"
            type="object"
            icon="fa-refresh"
            invisible="not product_id or is_locked"/>

</header>

<sheet>
    <field name="active" invisible="1"/>

    <div class="oe_button_box" name="button_box">

        <button name="action_view_package_usage"
                type="object"
                class="oe_stat_button"
                icon="fa-shopping-bag"
                invisible="not product_id">

            <field name="usage_count"
                   widget="statinfo"
                   string="Usage"/>

        </button>

    </div>

    <field name="is_locked" invisible="1"/>

    <group>
        <group>

            <field name="name"
                   readonly="is_locked"/>

            <field name="duration"
                   readonly="is_locked"/>

            <field name="discount_per"
                   readonly="is_locked"/>
            <field name="extra_discount_per"
                readonly="is_locked" help="Extra discount percentage for the package if applicable."/>

            <field name="valid"
                   readonly="is_locked"/>
            <field name="pos_config_ids"
                widget="many2many_tags"
                domain="[('enable_laundry_packages', '=', True)]"
                options="{'no_create': True, 'no_open': True}"/>

        </group>

        <group>

            <field name="total_value"
                   readonly="1"/>

            <field name="package_amount"
                   readonly="is_locked"/>

            <field name="product_id"
                   readonly="1"/>
            

        </group>

    </group>

    <notebook>

        <page string="Package Details">

            <field name="detail_ids"
                   readonly="is_locked">

                <list editable="bottom">

                    <field name="pos_category_id"/>

                    <field name="product_ids"
                           widget="many2many_tags"
                           domain="[('pos_categ_ids', 'in', pos_category_id)]"/>

                    <field name="qty"/>

                    <field name="value"
                           readonly="1"/>

                    

                </list>

            </field>

        </page>

    </notebook>

</sheet>

            </form>
        </field>
    </record>

        <!-- Search View -->
    <record id="view_package_rule_search" model="ir.ui.view">
        <field name="name">package.rule.search</field>
        <field name="model">package.rule</field>
        <field name="arch" type="xml">
            <search string="Package Templates">
                <field name="name"/>

                <separator/>

                <filter name="active_packages"
                        string="Active"
                        domain="[('active', '=', True)]"/>

                <filter name="archived_packages"
                        string="Archived"
                        domain="[('active', '=', False)]"/>

                <separator/>

                <filter name="valid_packages"
                        string="Valid"
                        domain="[('valid', '=', True)]"/>

                <filter name="invalid_packages"
                        string="Invalid"
                        domain="[('valid', '=', False)]"/>

                <separator/>

                
            </search>
        </field>
    </record>

</odoo>