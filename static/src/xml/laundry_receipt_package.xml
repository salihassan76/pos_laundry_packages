<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="pos_laundry_packages.LaundryReceiptPackage"
       t-inherit="pos_laundry.LaundryReceipt"
       t-inherit-mode="extension">

        <xpath expr="//div[contains(@class, 'pos-receipt-right-align')][strong[contains(text(), 'Total')]]" position="after">
            <br/>
            <t t-if="receipt.is_package_sale">
                <div class="pos-receipt-center-align">
                    <strong>PACKAGE PURCHASE</strong>
                </div>
            </t>
            <t t-if="receipt.is_package_usage">
                <div class="pos-receipt-center-align">
                    <strong>PAID BY PACKAGE</strong>
                </div>
            </t>
        </xpath>

    </t>

</templates>
