<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="pos_laundry_packages.OrderSummaryPackageExtension"
       t-inherit="point_of_sale.OrderSummary"
       t-inherit-mode="extension">

        <xpath expr="//div[@class='laundry-order-info p-2']/div" position="inside">

            <t t-if="pos.getOrder()?.uiState?.package_rule_name">
                <span class="text-info">
                    <strong>Package:</strong>
                    <t t-esc="pos.getOrder().uiState.package_rule_name"/>
                </span>
            </t>

        </xpath>

    </t>

</templates>