<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="pos_laundry_packages.CategorySelectorPackageBadge"
       t-inherit="point_of_sale.CategorySelector"
       t-inherit-mode="extension">

        <xpath expr="//button[hasclass('category-button')]" position="inside">

            <t t-if="category">

                <t t-set="badge"
                   t-value="this.getPackageCategoryBadge(category.id)"/>

                <t t-if="badge">

                    <span
                        t-att-class="'badge rounded-pill ms-1 package-category-badge ' +
                            (this.isPackageCategoryDisabled(category.id)
                                ? 'text-bg-danger'
                                : 'text-bg-info')">

                        <t t-esc="badge"/>

                    </span>

                </t>

            </t>

        </xpath>

    </t>

</templates>