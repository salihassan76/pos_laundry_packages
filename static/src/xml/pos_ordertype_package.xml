<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="pos_laundry_packages.OrderSummaryPackageExtension"
       t-inherit="point_of_sale.OrderSummary"
       t-inherit-mode="extension">

        <xpath expr="//div[contains(@class, 'laundry-order-info')]/div" position="inside">
            <t t-if="pos.getOrder()?.uiState?.package_rule_id">
                <div class="mt-1">
                    <strong>Package:</strong>
                    <t t-esc="pos.getOrder()?.uiState?.package_rule_name"/>
                </div>
            </t>
        </xpath>

    </t>

</templates>
